# ===== CAMPUS GPT — ENVIRONMENT VARIABLES =====
# Copy this file to .env.local for local development.
# DO NOT commit .env.local to git (it's in .gitignore).
# For Vercel: add these as Environment Variables in Dashboard → Settings → Environment Variables.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Set to 'mock' to run in dev mock auth mode (no Supabase needed)
VITE_SUPABASE_URL=mock
VITE_SUPABASE_ANON_KEY=mock
# Real Supabase values look like:
# VITE_SUPABASE_URL=https://xyzxyzxyz.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6Ikp...

# ─── LLM API ──────────────────────────────────────────────────────────────────
# Leave as 'mock' to get simulated AI responses for UI development
VITE_LLM_API_KEY=mock
VITE_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# Other providers:
# Groq: https://api.groq.com/openai/v1/chat/completions
# Mistral: https://api.mistral.ai/v1/chat/completions
# OpenRouter: https://openrouter.ai/api/v1/chat/completions
